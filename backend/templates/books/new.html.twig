{% extends 'base.html.twig' %}

{% block body %}
    <div class="row justify-content-center mt-4">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="d-flex align-items-center mb-4">
                <a href="{{ path('app_books_index') }}" class="btn btn-light rounded-circle me-3 shadow-sm">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="fw-bold mb-0" style="color: var(--primary-color);">Nouveau Livre</h2>
            </div>

            {{ form_start(form) }}
            <div class="card border-0 shadow-sm p-3 mb-4" style="border-radius: 20px;">
                <div class="card-body">

                    {# Section 1 : Infos de base #}
                    <div class="mb-4">
                        {{ form_label(form.title, null, {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                        {{ form_widget(form.title) }}
                        <div class="text-danger small">{{ form_errors(form.title) }}</div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.authors, null, {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                        {{ form_widget(form.authors) }}
                        <div class="form-text mt-1">{{ form.authors.vars.help }}</div>
                    </div>

                    {# Section 2 : Saga (Côte à côte) #}
                    <div class="row g-3 mb-4">
                        <div class="col-8">
                            {{ form_label(form.saga, null, {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                            {{ form_widget(form.saga) }}
                        </div>
                        <div class="col-4">
                            {{ form_label(form.number, "Tome", {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                            {{ form_widget(form.number) }}
                        </div>
                    </div>

                    {# Section 3 : Détails techniques #}
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            {{ form_label(form.number_of_page, "Pages", {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                            {{ form_widget(form.number_of_page) }}
                        </div>
                        <div class="col-6">
                            {{ form_label(form.month_of_purchase, "Date d'achat", {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                            {{ form_widget(form.month_of_purchase) }}
                        </div>
                    </div>

                    <div class="mb-0">
                        {{ form_label(form.genres, "Genres / Catégories", {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                        {{ form_widget(form.genres) }}
                    </div>

                    {# Section spécifique UPDATE (Status & Note) #}
                    {% if form.readingStatus is defined %}
                        <div class="mt-4 p-3 rounded-4 bg-light">
                            <h6 class="fw-bold small mb-3 text-uppercase" style="letter-spacing: 1px;">Ma lecture</h6>
                            <div class="mb-3">
                                {{ form_widget(form.readingStatus) }}
                            </div>
                            <div>
                                {{ form_label(form.rating, "Ma note", {'label_attr': {'class': 'fw-bold small mb-1'}}) }}
                                {{ form_widget(form.rating) }}
                            </div>
                        </div>
                    {% endif %}

                </div>
            </div>

            <div class="d-grid gap-2 mb-5">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow py-3">
                    Ajouter à ma bibliothèque
                </button>
                <a href="{{ path('app_books_index') }}" class="btn btn-link text-muted text-decoration-none">Annuler</a>
            </div>
            {{ form_end(form) }}

        </div>
    </div>
{% endblock %}